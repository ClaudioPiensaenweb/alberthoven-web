{
  "plugin": "piensa",
  "version": "1.0.0",
  "currentMode": null,
  "erp": {
    "url": "https://ssot.piensaenweb.com/api",
    "token": ""
  },
  "workflow": {
    "research": true,
    "reviewer": true,
    "autoEstado": true,
    "hookContextMonitor": true,
    "hookCheckUpdate": true,
    "modelEscalation": true
  },
  "models": {
    "default": "sonnet",
    "escalated": "opus",
    "escalation_criteria": {
      "sizing_threshold": ["L", "XL"],
      "retry_threshold": 3,
      "files_threshold": 5
    }
  },
  "git": {
    "commit_docs": true,
    "branch_strategy": "github-flow",
    "auto_stage_docs": true,
    "conventional_commits": true,
    "commit_types": ["feat", "fix", "docs", "style", "refactor", "chore"],
    "commit_language": "es"
  },
  "proyecto": {
    "nombre": "Alberto Luna Web",
    "tipo": "Landing / sitio estático",
    "cliente": "Alberto Luna",
    "stack": {
      "frontend": "HTML estático + Tailwind CSS (CDN)",
      "backend": "",
      "db": "",
      "testing": "",
      "runtime": "Browser",
      "package_manager": ""
    },
    "repo": "",
    "path": ""
  },
  "tipo_proyecto": "cliente",
  "design": {
    "paleta": {
      "acento":           "#C0C0C0",
      "acento_hover":     "#E8E8E8",
      "fondo":            "#080808",
      "fondo_secundario": "#0F0F0F",
      "titulos":          "#FFFFFF",
      "textos":           "#A8A8A8",
      "cromo_highlight":  "#F0F0F0",
      "cromo_sombra":     "#404040"
    },
    "tipografia": {
      "titulos": "Cormorant Garamond 700",
      "textos":  "Lato 400"
    },
    "estilo":    "dark-chrome-luxury",
    "industria": "música / composición sinfónica",
    "referencia_visual": "Jaguar F-Type — negro profundo + cromo/plata metálica",
    "logo":      "Logo ABH.png"
  },
  "subAgent": "",
  "skills": [],
  "skillsConfig": {
    "timeout": 3600,
    "retryOnFailure": true,
    "maxRetries": 1
  },
  "guardrails": {
    "enabled": true,
    "protect_main": true,
    "suggest_branch_naming": true,
    "warn_git_add_all": true
  },
  "team": {
    "experience_level": null,
    "first_run": true
  },
  "paths": {
    "briefing": ".planning/BRIEFING.md",
    "planificacion": ".planning/ROADMAP.md",
    "estado": ".planning/estado.md",
    "config": ".planning/config.json"
  }
}
